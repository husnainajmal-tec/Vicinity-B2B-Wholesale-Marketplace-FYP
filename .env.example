# ==========================================================================
# Vicinity Trade — Environment Variables (root example for both apps)
# --------------------------------------------------------------------------
# Copy this file:
#   - Server: copy the SERVER block into /server/.env
#   - Client: copy the CLIENT block into /client/.env
# ==========================================================================

# ------------------------------- SERVER -----------------------------------
# Port the Express API listens on
PORT=5000

# Node environment: development | production
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/vicinity_trade
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/vicinity_trade
MONGO_URI=mongodb://127.0.0.1:27017/vicinity_trade

# JWT secret used to sign auth tokens (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# URL of the client app (used for CORS + Socket.io origin)
CLIENT_URL=http://localhost:5173

# Cloudinary (optional — leave blank to use local disk storage in /server/uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------- CLIENT -----------------------------------
# Base URL of the backend API (Vite requires the VITE_ prefix)
VITE_API_URL=http://localhost:5000/api

# Base URL for the Socket.io connection
VITE_SOCKET_URL=http://localhost:5000
